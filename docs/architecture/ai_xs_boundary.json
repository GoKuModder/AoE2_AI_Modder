{
  "version": 1,
  "description": "AI/XS import boundary contract for Python modules.",
  "domains": {
    "ai": {
      "path_patterns": [
        "src/retrieval/**/*.py",
        "src/builds/ai_scripting_knowledge_build.py",
        "src/knowledge_builders/ai_scripting_builder.py",
        "tools/build_ai_scripting_knowledge.py"
      ],
      "module_prefixes": [
        "src.retrieval",
        "src.builds.ai_scripting_knowledge_build",
        "src.knowledge_builders.ai_scripting_builder",
        "tools.build_ai_scripting_knowledge"
      ]
    },
    "xs": {
      "path_patterns": [
        "src/integration/**/*.py",
        "tools/generate_xs_array_injection_demo.py"
      ],
      "module_prefixes": [
        "src.integration",
        "tools.generate_xs_array_injection_demo"
      ]
    },
    "shared": {
      "path_patterns": [
        "src/common/**/*.py",
        "src/writers/**/*.py",
        "src/knowledge_builders/utils.py",
        "src/interop/**/*.py",
        "tests/**/*.py",
        "tools/check_boundaries.py"
      ],
      "module_prefixes": [
        "src.common",
        "src.writers",
        "src.knowledge_builders.utils",
        "src.interop",
        "tools.check_boundaries"
      ]
    }
  },
  "interop_allowlist": {
    "module_patterns": [
      "src.interop.*"
    ],
    "notes": "Placeholder allowlist for approved AI/XS integration modules. Expand as bridge modules are formalized."
  },
  "rules": [
    {
      "name": "no_direct_ai_to_xs_import",
      "from_domain": "ai",
      "to_domain": "xs",
      "allowlist": "interop_allowlist"
    },
    {
      "name": "no_direct_xs_to_ai_import",
      "from_domain": "xs",
      "to_domain": "ai",
      "allowlist": "interop_allowlist"
    }
  ]
}
